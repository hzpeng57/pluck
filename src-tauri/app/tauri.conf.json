{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pluck",
  "version": "0.1.8",
  "identifier": "com.hzp.pluck",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pluck",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../binaries/pluck-git-bridge": "binaries/pluck-git-bridge"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/hzpeng57/pluck/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBQjlGNDgyODg0QTI5MEMKUldRTUtVcUlndlM1S3MzblIrRzVCYjh1WXg5bk9ha09RblBXdjlSbksyQXJBTEM1K3o0MDlLWkQK"
    }
  }
}
